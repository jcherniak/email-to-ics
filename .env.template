POSTMARK_API_KEY="uuid"

FROM_EMAIL=""

INBOUND_CONFIRMED_EMAIL="confirmed@example.com"

TO_TENTATIVE_EMAIL="tentative@example.com"
TO_CONFIRMED_EMAIL="confirmed@example.com"
ERROR_EMAIL="errors@example.com"

GOOGLE_MAPS_API_KEY="AIza..."
MAPBOX_API_KEY="pk..."
GEOCODER_ORDER=mapbox,google
GEOCODE_COMBINE_MODEL=~anthropic/claude-haiku-latest
GEOCODE_DEFAULT_COUNTRY=US
# Set to mapbox, google, or all/1 to make live geocoder integration tests fail instead of skip when keys are missing or unauthorized.
# Command-line/process environment values take precedence over this .env value.
TESTS_REQUIRE_GEOCODER_INTEGRATION=0

HTTP_AUTH_USERNAME="user"
HTTP_AUTH_PASSWORD="pass"

ALLOWED_MODELS=~openai/gpt-latest,~google/gemini-pro-latest,~anthropic/claude-opus-latest,~anthropic/claude-sonnet-latest,~openai/gpt-mini-latest,~google/gemini-flash-latest,~moonshotai/kimi-latest
DEFAULT_MODEL=~openai/gpt-latest
URL_DETECTION_MODEL="~google/gemini-flash-latest"
URL_DETECTION_FALLBACK_MODEL="~openai/gpt-mini-latest"
ALTERNATE_MODEL="~google/gemini-pro-latest"

OPENROUTER_KEY="sk-or-xxxxxxxxx"

# Oxylabs proxy configuration (optional)
OXYLABS_PROXY="pr.oxylabs.io:7777"
OXYLABS_USERNAME="customer-..."
OXYLABS_PASSWORD=""

# Scrapefly API key for fallback when regular fetching fails
SCRAPEFLY_API_KEY="scp-live-xxxxxxxxxx"

LOG_LEVEL=info

# Maximum number of times to process the same email (based on MessageID)
MAX_EMAIL_RETRIES=1
