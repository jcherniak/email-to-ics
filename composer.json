        "spatie/pdf-to-text": "^1.52",
        "symfony/html-sanitizer": "^6.4",
        "html2text/html2text": "^4.3",
        "opis/json-schema": "^2.4",
        "eluceo/ical": "^2.14",
        "zoon/puphpeteer": "^1.0",
        "slim/slim": "^4",
        "slim/psr7": "^1"
    },
    "autoload": {
        "psr-4": {
            "Jcherniak\\EmailToIcs\\": "src/"
